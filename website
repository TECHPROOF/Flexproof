<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
var pkgs={starter:{m:750,pct:0.12},medium:{m:1500,pct:0.10},advanced:{m:2500,pct:0.08}};
function fmt(n){return'€ '+Math.round(n).toLocaleString('nl-NL')}
function calc(){
  var sal=parseInt(document.getElementById('sal').value);
  var h=parseInt(document.getElementById('h').value);
  var pkg=pkgs[document.getElementById('pkg').value];
  document.getElementById('sal-out').textContent=fmt(sal);
  document.getElementById('h-out').textContent=h+' hire'+(h>1?'s':'');
  var bureau=sal*0.225*h;
  var ret=pkg.m*12;
  var fees=sal*pkg.pct*h;
  var fp=ret+fees;
  var save=bureau-fp;
  var perBureau=sal*0.225;
  var perRet=h>0?ret/h:0;
  var perFee=sal*pkg.pct;
  var perTotal=perRet+perFee;
  document.getElementById('r-bureau').textContent=fmt(bureau);
  document.getElementById('r-ret').textContent=fmt(ret);
  document.getElementById('r-fees').textContent=fmt(fees);
  document.getElementById('r-fees-d').textContent=h+' \xd7 '+(pkg.pct*100)+'% van '+fmt(sal);
  var se=document.getElementById('r-save');
  se.textContent=save>=0?fmt(save):'- '+fmt(Math.abs(save));
  se.style.color=save>=0?'#00C896':'#E24B4A';
  document.getElementById('r-save-d').textContent=(save>=0?'goedkoper':'duurder')+' dan bureau';
  document.getElementById('b-bureau').textContent=fmt(perBureau);
  document.getElementById('b-ret').textContent=fmt(perRet);
  document.getElementById('b-fee').textContent=fmt(perFee);
  var te=document.getElementById('b-total');
  te.textContent=fmt(perTotal);
